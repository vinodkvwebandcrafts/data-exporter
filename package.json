{
  "version": "0.1.0",
  "keywords": [
    "strapi",
    "plugin",
    "strapi-plugin",
    "export",
    "xlsx",
    "excel"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "tsc -p admin/tsconfig.json --noEmit",
    "test:ts:back": "tsc -p server/tsconfig.json --noEmit",
    "test:unit": "vitest run --dir tests/unit",
    "test:unit:watch": "vitest --dir tests/unit",
    "test:component": "vitest run --dir tests/component --environment jsdom",
    "test:integration": "jest --config tests/integration/jest.config.js --runInBand",
    "test": "yarn test:unit && yarn test:component && yarn test:integration"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "qs": "^6.15.1"
  },
  "devDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.1.0",
    "@strapi/strapi": "^5.43.0",
    "@strapi/typescript-utils": "^5.43.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/qs": "^6.15.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "better-sqlite3": "^12.9.0",
    "jest": "^30.3.0",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.1.0",
    "@strapi/strapi": "^5.43.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.1"
  },
  "strapi": {
    "kind": "plugin",
    "name": "data-exporter",
    "displayName": "Data Exporter",
    "description": "Export Strapi v5 collections to xlsx files from the admin panel."
  },
  "name": "strapi-plugin-data-exporter",
  "description": "Export Strapi v5 collections to xlsx files from the admin panel.",
  "license": "MIT",
  "author": "vinod <vinod.kv@webandcrafts.com>",
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  }
}
